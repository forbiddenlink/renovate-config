{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Shared Renovate config for all forbiddenlink repos",
  "extends": [
    "config:recommended",
    "group:allNonMajor",
    ":automergeMinor",
    ":automergePatch",
    ":semanticCommitTypeAll(chore)"
  ],
  "labels": ["dependencies"],
  "schedule": ["before 9am on Monday"],
  "timezone": "America/New_York",
  "prHourlyLimit": 3,
  "prConcurrentLimit": 5,
  "packageRules": [
    {
      "description": "Auto-merge all patch updates",
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Auto-merge minor updates for trusted packages",
      "matchUpdateTypes": ["minor"],
      "matchPackagePatterns": [
        "^@types/",
        "^eslint",
        "^@eslint",
        "^typescript-eslint",
        "^biome",
        "^@biomejs",
        "^vitest",
        "^playwright",
        "^@playwright",
        "^@tanstack",
        "^lucide-react",
        "^tailwindcss",
        "^postcss"
      ],
      "automerge": true
    },
    {
      "description": "Group Sentry packages",
      "matchPackagePatterns": ["^@sentry/"],
      "groupName": "sentry"
    },
    {
      "description": "Group Supabase packages",
      "matchPackagePatterns": ["^@supabase/"],
      "groupName": "supabase"
    },
    {
      "description": "Group Next.js packages",
      "matchPackagePatterns": ["^next$", "^@next/"],
      "groupName": "next.js"
    },
    {
      "description": "Group Prisma packages",
      "matchPackagePatterns": ["^prisma$", "^@prisma/"],
      "groupName": "prisma"
    },
    {
      "description": "Pin major updates for review",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "major"]
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  }
}
